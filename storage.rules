rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /guides/{guideId}/{fileName} {
      // Publiczny odczyt zdjęć i dokumentów w przewodnikach (goście potrzebują dostępu)
      allow read: if true;

      // Zapis: wyłącznie zalogowany użytkownik.
      // Ograniczenie: max 5MB, typy MIME: obrazy, PDF, DOC/DOCX
      // TODO: PRZED LAUNCHEM APKI - PRZYWRÓCIĆ RESTRYKCYJNE REGUŁY
      // Poniższe pozwala na zapis dla każdego zalogowanego, omijając cross-service check dla testowej wersji aplikacji.
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024 
                   && (request.resource.contentType.matches('image/.*') ||
                       request.resource.contentType == 'application/pdf' ||
                       request.resource.contentType == 'application/msword' ||
                       request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    }
  }
}
