{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vite Dev Server (Frontend)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "Firebase Emulators (All)",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["emulators:start"],
      "port": 4000
    },
    {
      "name": "Firebase Functions Emulator",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["emulators:start", "--only", "functions"],
      "port": 5001
    }
  ]
}
