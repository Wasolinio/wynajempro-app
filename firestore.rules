rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // GLOBALNA FUNKCJA BEZPIECZEŃSTWA
    // Sprawdza: czy użytkownik jest zalogowany, jest właścicielem dokumentu,
    // ORAZ ma zweryfikowany adres email.
    // =====================================================================
    function isOwnerAndVerified(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email_verified == true;
    }

    // =====================================================================
    // FUNKCJA SUBSKRYPCJI
    // Pobiera status z Custom Claims (token), z fallbackiem na odczyt dokumentu.
    // =====================================================================
    function checkFallbackSubscription(userId) {
      let userData = get(/databases/$(database)/documents/users/$(userId)).data;
      
      let isTrialing = userData.status == 'trialing';
      let validTimestamp = isTrialing && userData.trialEndsAt is timestamp && userData.trialEndsAt > request.time;
      let validString = isTrialing && userData.trialEndsAt is string && timestamp.value(userData.trialEndsAt) > request.time;
      
      return userData.status == 'active' || validTimestamp || validString;
    }

    function hasActiveSubscription(userId) {
      let token = request.auth.token;
      return ('stripeStatus' in token && (
          token.stripeStatus == 'active' || 
          (token.stripeStatus == 'trialing' && 'trialEndsAt' in token && token.trialEndsAt > request.time.toMillis())
        )) ||
        (!('stripeStatus' in token) && checkFallbackSubscription(userId));
    }

    // =====================================================================
    // FUNKCJE WALIDACJI SCHEMATU (Schema Validation)
    // =====================================================================
    function isValidRental(data) {
      return data.keys().hasAll(['type', 'date'])
        && (data.type == 'booking' || data.type == 'utility' || data.type == 'reminder')
        && data.date is string
        && data.date.size() >= 10
        && (!('income' in data) || data.income is number)
        && (!('advancePayment' in data) || data.advancePayment is number)
        && (!('commission' in data) || data.commission is number)
        && (!('tax' in data) || data.tax is number)
        && (!('vat' in data) || data.vat is number)
        && (!('utilities' in data) || data.utilities is number)
        && (!('guest' in data) || data.guest is string)
        && (!('property' in data) || data.property is string)
        && (!('source' in data) || data.source is string)
        && (!('endDate' in data) || data.endDate is string);
    }

    function isValidSettings(docId, data) {
      let knownIds = ['reminders', 'properties', 'sources', 'categories', 'syncLinks', 'tax', 'hostProfile'];
      return docId in knownIds
          && (docId == 'reminders' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'properties' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'sources' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'categories' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'syncLinks' ? (!('links' in data) || data.links is map) : true)
          && (docId == 'tax' ? (!('rate' in data) || data.rate is number) : true);
    }

    // =====================================================================
    // WALIDACJA GUIDE (Schema Validation dla dokumentów przewodników)
    // Ogranicza listę dozwolonych pól oraz ich typy.
    // =====================================================================
    function isValidGuide(data) {
      return data.keys().hasAll(['name', 'ownerId'])
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 200
        && data.ownerId is string
        && (!('propertyId' in data) || (data.propertyId is string && data.propertyId.size() <= 200))
        && (!('checkInInfo' in data) || (data.checkInInfo is string && data.checkInInfo.size() <= 5000))
        && (!('houseRules' in data) || (data.houseRules is string && data.houseRules.size() <= 10000))
        && (!('ppoRules' in data) || (data.ppoRules is string && data.ppoRules.size() <= 10000))
        && (!('mapLink' in data) || (data.mapLink is string && data.mapLink.size() <= 500))
        && (!('wifiNetwork' in data) || (data.wifiNetwork is string && data.wifiNetwork.size() <= 100))
        && (!('wifiPassword' in data) || (data.wifiPassword is string && data.wifiPassword.size() <= 100))
        && (!('doorPin' in data) || (data.doorPin is string && data.doorPin.size() <= 50))
        && (!('attractions' in data) || data.attractions is list)
        && data.keys().size() <= 20;
    }

    // =====================================================================
    // PROFIL UŻYTKOWNIKA — users/{userId}
    // =====================================================================
    // Odczyt: tylko właściciel (niezależnie od weryfikacji i subskrypcji)
    // Tworzenie: właściciel, status MUSI być 'trialing'
    // Aktualizacja: właściciel z zweryfikowanym mailem, ale NIE MOŻE zmieniać
    //   pól chronionych (status, trialEndsAt)
    // =====================================================================
    match /users/{userId} {

      allow read: if request.auth != null && request.auth.uid == userId;

      // Zablokowano Privilege Escalation (Account Takeover) — atakujący nie może wstrzyknąć stripeCustomerId na starcie
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.status == 'trialing'
                    && !('stripeCustomerId' in request.resource.data)
                    && !('stripeSubscriptionId' in request.resource.data);

      allow update: if isOwnerAndVerified(userId)
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.trialEndsAt == resource.data.trialEndsAt
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['stripeCustomerId', 'stripeSubscriptionId']);

      // Rezerwacje, wydatki, zadania (zasoby biznesowe) - wymagają subskrypcji
      match /rentals/{docId} {
        allow read: if isOwnerAndVerified(userId) && hasActiveSubscription(userId);
        allow create, update: if isOwnerAndVerified(userId) && hasActiveSubscription(userId) && isValidRental(request.resource.data);
        allow delete: if isOwnerAndVerified(userId) && hasActiveSubscription(userId);
      }

      // Ustawienia użytkownika - wymagają subskrypcji
      match /settings/{docId} {
        // hostProfile jest odczytywany publicznie (kontakt w przewodniku dla gości)
        allow read: if docId == 'hostProfile'
                    || (isOwnerAndVerified(userId) && hasActiveSubscription(userId));
        allow create, update: if isOwnerAndVerified(userId) && hasActiveSubscription(userId) && isValidSettings(docId, request.resource.data);
        allow delete: if isOwnerAndVerified(userId) && hasActiveSubscription(userId);
      }

      // Sesje checkout - NIE wymagają subskrypcji (aby móc opłacić)
      match /checkout_sessions/{docId} {
        allow read, delete: if isOwnerAndVerified(userId);
        allow create, update: if isOwnerAndVerified(userId)
                              && request.resource.data.keys().size() <= 10
                              && (!('sessionId' in request.resource.data) || request.resource.data.sessionId is string);
      }
    }

    // =====================================================================
    // PRZEWODNIKI (Guest Guides) — guides/{guideId}
    // =====================================================================
    // BEZPIECZEŃSTWO: Główny dokument zawiera tylko dane publiczne (tytuł, cover, atrakcje).
    // Pola wrażliwe (wifi, kody) ukryte są w subkolekcji secrets, odczyt warunkowy.
    // =====================================================================
    match /guides/{guideId} {
      allow read: if true; // Publiczny dostęp do bazowego dokumentu (bez sekretów)

      allow create: if isOwnerAndVerified(request.auth.uid)
                    && hasActiveSubscription(request.auth.uid)
                    && request.resource.data.ownerId == request.auth.uid
                    && isValidGuide(request.resource.data);

      allow update: if isOwnerAndVerified(request.auth.uid)
                    && hasActiveSubscription(request.auth.uid)
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == request.auth.uid
                    && isValidGuide(request.resource.data);

      allow delete: if isOwnerAndVerified(request.auth.uid)
                    && resource.data.ownerId == request.auth.uid;

      // =====================================================================
      // SEKRETY (Wrażliwe dane: WiFi, Pin dostępu)
      // Odczyt: Właściciel przewodnika LUB anonimowy gość, który posiada
      // autoryzowany rekord (podpis) w kolekcji signatures
      // =====================================================================
      match /secrets/data {
        allow read: if (request.auth != null && get(/databases/$(database)/documents/guides/$(guideId)).data.ownerId == request.auth.uid)
                    || (request.auth != null && exists(/databases/$(database)/documents/guides/$(guideId)/signatures/$(request.auth.uid)));
        
        allow write: if isOwnerAndVerified(request.auth.uid)
                     && get(/databases/$(database)/documents/guides/$(guideId)).data.ownerId == request.auth.uid;
      }

      // =====================================================================
      // PODPISY REGULAMINÓW (Zablokowanie DoS)
      // Tworzone tylko przez autentykowanego użytkownika (signInAnonymously),
      // gdzie ID dokumentu = UID sesji. Blokuje to botom farmowanie logów.
      // =====================================================================
      match /signatures/{signatureId} {
        allow get: if request.auth != null && request.auth.uid == signatureId;
        allow create: if request.auth != null 
                      && request.auth.uid == signatureId
                      && request.resource.data.keys().size() <= 10
                      && request.resource.data.keys().hasAll(['acceptedAt'])
                      && request.resource.data.acceptedAt is timestamp
                      && (!('name' in request.resource.data) || (request.resource.data.name is string && request.resource.data.name.size() <= 200))
                      && (!('signature' in request.resource.data) || (request.resource.data.signature is string && request.resource.data.signature.size() <= 10000))
                      && (!('acceptedHouseRulesSnapshot' in request.resource.data) || (request.resource.data.acceptedHouseRulesSnapshot is string && request.resource.data.acceptedHouseRulesSnapshot.size() <= 15000))
                      && (!('acceptedPpoRulesSnapshot' in request.resource.data) || (request.resource.data.acceptedPpoRulesSnapshot is string && request.resource.data.acceptedPpoRulesSnapshot.size() <= 15000));
        allow update: if false; 
        allow delete: if request.auth != null && get(/databases/$(database)/documents/guides/$(guideId)).data.ownerId == request.auth.uid;
        allow list: if request.auth != null && get(/databases/$(database)/documents/guides/$(guideId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
