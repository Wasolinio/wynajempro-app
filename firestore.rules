rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // GLOBALNA FUNKCJA BEZPIECZEŃSTWA
    // Sprawdza: czy użytkownik jest zalogowany, jest właścicielem dokumentu,
    // ORAZ ma zweryfikowany adres email.
    // =====================================================================
    function isOwnerAndVerified(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email_verified == true;
    }

    // =====================================================================
    // FUNKCJA SUBSKRYPCJI
    // Pobiera status z Custom Claims (token), z fallbackiem na odczyt dokumentu.
    // =====================================================================
    function checkFallbackSubscription(userId) {
      let userData = get(/databases/$(database)/documents/users/$(userId)).data;
      return userData.status == 'active'
        || (userData.status == 'trialing' 
            && userData.trialEndsAt is timestamp 
            && userData.trialEndsAt > request.time);
    }

    function hasActiveSubscription(userId) {
      let token = request.auth.token;
      return ('stripeStatus' in token && (
          token.stripeStatus == 'active' || 
          (token.stripeStatus == 'trialing' && 'trialEndsAt' in token && token.trialEndsAt > request.time.toMillis())
        )) ||
        (!('stripeStatus' in token) && checkFallbackSubscription(userId));
    }

    // =====================================================================
    // FUNKCJE WALIDACJI SCHEMATU (Schema Validation)
    // =====================================================================
    function isValidRental(data) {
      return data.keys().hasAll(['type', 'date'])
        && (data.type == 'booking' || data.type == 'utility' || data.type == 'reminder')
        && data.date is string
        && data.date.size() >= 10
        && (!('income' in data) || data.income is number)
        && (!('advancePayment' in data) || data.advancePayment is number)
        && (!('commission' in data) || data.commission is number)
        && (!('tax' in data) || data.tax is number)
        && (!('vat' in data) || data.vat is number)
        && (!('utilities' in data) || data.utilities is number)
        && (!('guest' in data) || data.guest is string)
        && (!('property' in data) || data.property is string)
        && (!('source' in data) || data.source is string)
        && (!('endDate' in data) || data.endDate is string);
    }

    function isValidSettings(docId, data) {
      let knownIds = ['reminders', 'properties', 'sources', 'categories', 'syncLinks', 'tax', 'hostProfile'];
      return docId in knownIds
          && (docId == 'reminders' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'properties' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'sources' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'categories' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'syncLinks' ? (!('links' in data) || data.links is map) : true)
          && (docId == 'tax' ? (!('rate' in data) || data.rate is number) : true);
    }

    // =====================================================================
    // PROFIL UŻYTKOWNIKA — users/{userId}
    // =====================================================================
    // Odczyt: tylko właściciel (niezależnie od weryfikacji i subskrypcji)
    // Tworzenie: właściciel, status MUSI być 'trialing'
    // Aktualizacja: właściciel z zweryfikowanym mailem, ale NIE MOŻE zmieniać
    //   pól chronionych (status, trialEndsAt)
    // =====================================================================
    match /users/{userId} {

      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.status == 'trialing';

      allow update: if isOwnerAndVerified(userId)
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.trialEndsAt == resource.data.trialEndsAt;

      // Rezerwacje, wydatki, zadania (zasoby biznesowe) - wymagają subskrypcji
      match /rentals/{docId} {
        allow read: if isOwnerAndVerified(userId) && hasActiveSubscription(userId);
        allow create, update: if isOwnerAndVerified(userId) && hasActiveSubscription(userId) && isValidRental(request.resource.data);
        allow delete: if isOwnerAndVerified(userId) && hasActiveSubscription(userId);
      }

      // Ustawienia użytkownika - wymagają subskrypcji
      match /settings/{docId} {
        allow read: if isOwnerAndVerified(userId) && hasActiveSubscription(userId);
        allow create, update: if isOwnerAndVerified(userId) && hasActiveSubscription(userId) && isValidSettings(docId, request.resource.data);
        allow delete: if isOwnerAndVerified(userId) && hasActiveSubscription(userId);
      }

      // Sesje checkout - NIE wymagają subskrypcji (aby móc opłacić)
      match /checkout_sessions/{docId} {
        allow read, write: if isOwnerAndVerified(userId);
      }
    }

    // =====================================================================
    // PRZEWODNIKI (Guest Guides) — guides/{guideId}
    // =====================================================================
    match /guides/{guideId} {
      allow read: if true; // Publiczny dostęp dla gości
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
  }
}
