rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // GLOBALNA FUNKCJA BEZPIECZEŃSTWA
    // =====================================================================
    function isOwnerAndVerified(userId) {
      // email_verified: konta Google mają true od dostawcy; anonimowi goście nie
      // przechodzą przez tę funkcję (podpisy/sekrety mają własne reguły).
      // .get(..., false) = fail-closed przy braku klucza w tokenie.
      return request.auth != null
        && request.auth.uid == userId
        && request.auth.token.get('email_verified', false) == true;
    }

    // =====================================================================
    // FUNKCJA SUBSKRYPCJI
    // =====================================================================
    function checkFallbackSubscription(userId) {
      let docSnap = get(/databases/$(database)/documents/users/$(userId));
      let docData = docSnap != null ? docSnap.data : {};

      // webhook Stripe pisze 'status'; 'accountStatus' honorowany dla danych historycznych
      let status = docData.get('status', docData.get('accountStatus', 'none'));

      // active → wstęp; trialing → tylko z żywym trialEndsAt (Timestamp).
      // trialEndsAt zapisany jako string (stare dane) nie przedłuża trialu — fail-closed.
      return status == 'active'
          || (status == 'trialing'
              && docData.get('trialEndsAt', null) != null
              && docData.trialEndsAt is timestamp
              && docData.trialEndsAt > request.time);
    }

    function hasActiveSubscription(userId) {
      // Szybka ścieżka: claim stripeStatus z webhooka (bez odczytu dokumentu);
      // past_due/canceled/trialing NIE przechodzą claimem — o trialu decyduje
      // data w dokumencie (fallback). Fail-closed przez .get().
      return request.auth.token.get('stripeStatus', '') == 'active'
          || checkFallbackSubscription(userId);
    }

    // =====================================================================
    // FUNKCJE WALIDACJI SCHEMATU (Schema Validation, N3)
    // Walidacja działa na dokumencie PO merge'u (update), więc allowlisty
    // muszą obejmować także pola historyczne/z synca iCal.
    // =====================================================================
    function optStr(data, k, max) {
      return !(k in data) || (data[k] is string && data[k].size() <= max);
    }
    function optNum(data, k) {
      return !(k in data) || data[k] is number;
    }
    function optBool(data, k) {
      return !(k in data) || data[k] is bool;
    }

    function isValidRental(data) {
      // pola: formularz (ManagerApp.getDefaultRentalState) + sync iCal (functions)
      // + aktualizacje zadań (WynajemContext: directionsSent/keycodeSent)
      // + 'id' legacy: stare wersje zapisywały id w dokumencie (test produkcji 2026-07-10:
      //   4 takie rezerwacje istnieją); obecny kod odcina id przy zapisie
      return data.keys().hasOnly(['type', 'source', 'property', 'category', 'guest', 'email', 'phone',
              'guestNote', 'text', 'date', 'endDate', 'income', 'advancePayment', 'isAdvancePaid',
              'commission', 'utilities', 'tax', 'vat', 'isPaid', 'isCompleted', 'completedTasks',
              'syncId', 'directionsSent', 'keycodeSent', 'id', 'guests'])
          && data.get('type', '') in ['booking', 'utility', 'reminder']
          && data.date is string && data.date.size() <= 30
          && optStr(data, 'endDate', 30)
          && optStr(data, 'source', 300) && optStr(data, 'property', 300)
          && optStr(data, 'category', 300) && optStr(data, 'guest', 300)
          && optStr(data, 'email', 320) && optStr(data, 'phone', 50)
          && optStr(data, 'guestNote', 5000) && optStr(data, 'text', 5000)
          && optStr(data, 'syncId', 300) && optStr(data, 'id', 100)
          && optNum(data, 'income') && optNum(data, 'advancePayment')
          && optNum(data, 'commission') && optNum(data, 'utilities')
          && optNum(data, 'tax') && optNum(data, 'vat') && optNum(data, 'guests')
          && optBool(data, 'isAdvancePaid') && optBool(data, 'isPaid') && optBool(data, 'isCompleted')
          && optBool(data, 'directionsSent') && optBool(data, 'keycodeSent')
          && (!('completedTasks' in data) || data.completedTasks is map);
    }

    function isValidSettings(docId, data) {
      let knownIds = ['reminders', 'properties', 'sources', 'categories', 'syncLinks', 'tax', 'hostProfile', 'publicContact', 'recurringCosts'];
      return docId in knownIds
          && (docId == 'reminders' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'properties' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'sources' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'categories' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'recurringCosts' ? (!('items' in data) || data.items is list) : true)
          && (docId == 'syncLinks' ? (!('links' in data) || data.links is map) : true)
          && (docId == 'tax' ? (!('rate' in data) || data.rate is number) : true)
          && (docId == 'hostProfile' ? (
                data.keys().hasOnly(['entityName', 'identifierType', 'taxIdentifier', 'address', 'phone', 'email', 'publicEmail', 'showPublicContact'])
                && optStr(data, 'entityName', 300) && optStr(data, 'identifierType', 20)
                && optStr(data, 'taxIdentifier', 30) && optStr(data, 'address', 500)
                && optStr(data, 'phone', 50) && optStr(data, 'email', 320)
                && optStr(data, 'publicEmail', 320) && optBool(data, 'showPublicContact')
              ) : true)
          && (docId == 'publicContact' ? (
                data.keys().hasOnly(['entityName', 'phone', 'email'])
                && optStr(data, 'entityName', 300) && optStr(data, 'phone', 50) && optStr(data, 'email', 320)
              ) : true);
    }

    // =====================================================================
    // WALIDACJA GUIDE (Schema Validation dla dokumentów przewodników)
    // Dwa kształty w kolekcji guides: przewodnik gościa oraz strona opinii
    // (type:'review', X13). Ogranicza listę dozwolonych pól oraz ich typy.
    // =====================================================================
    function isValidReviewPage(data) {
      return data.keys().hasOnly(['type', 'ownerId', 'property', 'title', 'message', 'links', 'createdAt', 'updatedAt'])
          && optStr(data, 'property', 300)
          && optStr(data, 'title', 300)
          && optStr(data, 'message', 5000)
          && data.links is list && data.links.size() <= 20;
    }
    function isValidGuestGuide(data) {
      // wifiNetwork/wifiPassword/doorPin: legacy sekrety na STARYCH dokumentach —
      // dopuszczone w merge'u aktualizacji; front pisze je wyłącznie do secrets/data
      return data.keys().hasOnly(['id', 'name', 'propertyId', 'coverImage', 'checkInInfo', 'houseRules',
              'houseRulesFile', 'ppoRules', 'mapLink', 'attractions', 'hasSensitiveData',
              'ownerId', 'createdAt', 'updatedAt', 'wifiNetwork', 'wifiPassword', 'doorPin'])
          && data.name is string && data.name.size() > 0 && data.name.size() <= 300
          && optStr(data, 'id', 100) && optStr(data, 'propertyId', 300)
          && optStr(data, 'coverImage', 2048) && optStr(data, 'mapLink', 2048)
          && optStr(data, 'checkInInfo', 15000) && optStr(data, 'houseRules', 15000) && optStr(data, 'ppoRules', 15000)
          && (!('houseRulesFile' in data) || data.houseRulesFile == null || data.houseRulesFile is map)
          && (!('attractions' in data) || (data.attractions is list && data.attractions.size() <= 100))
          && optBool(data, 'hasSensitiveData')
          && optStr(data, 'wifiNetwork', 200) && optStr(data, 'wifiPassword', 200) && optStr(data, 'doorPin', 50);
    }
    function isValidGuide(data) {
      return data.get('type', '') == 'review' ? isValidReviewPage(data) : isValidGuestGuide(data);
    }

    // =====================================================================
    // PROFIL UŻYTKOWNIKA — users/{userId}
    // =====================================================================
    // Odczyt: tylko właściciel (niezależnie od weryfikacji i subskrypcji)
    // Tworzenie: właściciel, status MUSI być 'trialing'
    // Aktualizacja: właściciel z zweryfikowanym mailem, ale NIE MOŻE zmieniać
    //   pól chronionych (status, trialEndsAt)
    // =====================================================================
    match /users/{userId} {

      allow read: if request.auth != null && request.auth.uid == userId;

      // Zablokowano Privilege Escalation (Account Takeover) — atakujący nie może wstrzyknąć stripeCustomerId na starcie
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.status == 'trialing'
                    && !('stripeCustomerId' in request.resource.data)
                    && !('stripeSubscriptionId' in request.resource.data);

      allow update: if isOwnerAndVerified(userId)
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.trialEndsAt == resource.data.trialEndsAt
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['stripeCustomerId', 'stripeSubscriptionId']);

      // Rezerwacje, wydatki, zadania (zasoby biznesowe) - wymagają subskrypcji
      match /rentals/{docId} {
        allow read: if isOwnerAndVerified(userId) && hasActiveSubscription(userId);
        allow create, update: if isOwnerAndVerified(userId) && hasActiveSubscription(userId) && isValidRental(request.resource.data);
        allow delete: if isOwnerAndVerified(userId) && hasActiveSubscription(userId);
      }

      // Ustawienia użytkownika - wymagają subskrypcji
      match /settings/{docId} {
        // publicContact: wąski publiczny odczyt (kontakt w przewodniku dla gości).
        // hostProfile z taxIdentifier (może być PESEL) i adresem NIE jest już
        // publiczny — wcześniej każdy znający uid czytał pełne dane. Audyt N5 🟡5.
        allow read: if docId == 'publicContact'
                    || (isOwnerAndVerified(userId) && hasActiveSubscription(userId));
        allow create, update: if isOwnerAndVerified(userId) && hasActiveSubscription(userId) && isValidSettings(docId, request.resource.data);
        allow delete: if isOwnerAndVerified(userId) && hasActiveSubscription(userId);
      }

      // Sesje checkout - NIE wymagają subskrypcji (aby móc opłacić)
      match /checkout_sessions/{docId} {
        allow read, delete: if isOwnerAndVerified(userId);
        allow create, update: if isOwnerAndVerified(userId)
                              && request.resource.data.keys().size() <= 10
                              && (!('sessionId' in request.resource.data) || request.resource.data.sessionId is string);
      }
    }

    // =====================================================================
    // PRZEWODNIKI (Guest Guides) — guides/{guideId}
    // =====================================================================
    // BEZPIECZEŃSTWO: Główny dokument zawiera tylko dane publiczne (tytuł, cover, atrakcje).
    // Pola wrażliwe (wifi, kody) ukryte są w subkolekcji secrets, odczyt warunkowy.
    // =====================================================================
    match /guides/{guideId} {
      // get: publiczny (gość zna link); list: TYLKO właściciel nad własnymi dokumentami.
      // Otwarte `allow read` obejmowało też list — anonim mógł zrzucić CAŁĄ kolekcję
      // (wszyscy klienci, adresy, instrukcje wejścia). Audyt N5 🔴1.
      allow get: if true;
      allow list: if request.auth != null && resource.data.ownerId == request.auth.uid;

      // legacy sekrety dozwolone tylko w merge'u UPDATE starych dokumentów —
      // NOWY publiczny dokument nie może ich zawierać (hardening z przeglądu N3)
      allow create: if isOwnerAndVerified(request.auth.uid)
                    && hasActiveSubscription(request.auth.uid)
                    && request.resource.data.ownerId == request.auth.uid
                    && !request.resource.data.keys().hasAny(['wifiNetwork', 'wifiPassword', 'doorPin'])
                    && isValidGuide(request.resource.data);

      // legacy sekrety wolno wyłącznie USUWAĆ (migracja przy zapisie) — nigdy
      // dodawać ani zmieniać na publicznym dokumencie. Audyt N5 🔴2.
      allow update: if isOwnerAndVerified(request.auth.uid)
                    && hasActiveSubscription(request.auth.uid)
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == request.auth.uid
                    && !request.resource.data.diff(resource.data).addedKeys().hasAny(['wifiNetwork', 'wifiPassword', 'doorPin'])
                    && !request.resource.data.diff(resource.data).changedKeys().hasAny(['wifiNetwork', 'wifiPassword', 'doorPin'])
                    && isValidGuide(request.resource.data);

      // Kasowanie WYŁĄCZNIE przez callable deleteGuide (Admin SDK): kliencki delete
      // bazowego dokumentu nie kaskaduje na secrets/signatures/Storage i osierociłby
      // dane gości — dokładnie to, co zamyka F3 (audyt N5 🟡B). Zamknięte dla klienta.
      allow delete: if false;

      // =====================================================================
      // SEKRETY (Wrażliwe dane: WiFi, Pin dostępu)
      // Odczyt: Właściciel przewodnika LUB anonimowy gość, który posiada
      // autoryzowany rekord (podpis) w kolekcji signatures
      // =====================================================================
      match /secrets/data {
        allow read: if (request.auth != null && get(/databases/$(database)/documents/guides/$(guideId)).data.ownerId == request.auth.uid)
                    || (request.auth != null && exists(/databases/$(database)/documents/guides/$(guideId)/signatures/$(request.auth.uid)));
        
        allow write: if isOwnerAndVerified(request.auth.uid)
                     && get(/databases/$(database)/documents/guides/$(guideId)).data.ownerId == request.auth.uid;
      }

      // =====================================================================
      // PODPISY REGULAMINÓW (Zablokowanie DoS)
      // Tworzone tylko przez autentykowanego użytkownika (signInAnonymously),
      // gdzie ID dokumentu = UID sesji. Blokuje to botom farmowanie logów.
      // =====================================================================
      match /signatures/{signatureId} {
        allow get: if request.auth != null && request.auth.uid == signatureId;
        allow create: if request.auth != null 
                      && request.auth.uid == signatureId
                      && request.resource.data.keys().size() <= 10
                      && request.resource.data.keys().hasAll(['acceptedAt'])
                      && request.resource.data.acceptedAt is timestamp
                      && (!('name' in request.resource.data) || (request.resource.data.name is string && request.resource.data.name.size() <= 200))
                      && (!('signature' in request.resource.data) || (request.resource.data.signature is string && request.resource.data.signature.size() <= 10000))
                      && (!('acceptedHouseRulesSnapshot' in request.resource.data) || (request.resource.data.acceptedHouseRulesSnapshot is string && request.resource.data.acceptedHouseRulesSnapshot.size() <= 15000))
                      && (!('acceptedPpoRulesSnapshot' in request.resource.data) || (request.resource.data.acceptedPpoRulesSnapshot is string && request.resource.data.acceptedPpoRulesSnapshot.size() <= 15000));
        allow update: if false; 
        allow delete: if request.auth != null && get(/databases/$(database)/documents/guides/$(guideId)).data.ownerId == request.auth.uid;
        allow list: if request.auth != null && get(/databases/$(database)/documents/guides/$(guideId)).data.ownerId == request.auth.uid;
      }
    }

    // =====================================================================
    // NEWSLETTER SUBSCRIBERS
    // =====================================================================
    match /newsletter_subscribers/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'subscribedAt', 'source'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*');
      allow read, update, delete: if false;
    }

    // =====================================================================
    // WIADOMOŚCI Z FORMULARZA KONTAKTOWEGO (Known-Issues #6)
    // Create-only jak newsletter; odczyt wyłącznie w konsoli Firebase.
    // =====================================================================
    match /contact_messages/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'message', 'createdAt', 'source'])
                    && request.resource.data.keys().hasAll(['email', 'message', 'createdAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*')
                    && request.resource.data.email.size() <= 320
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000
                    && request.resource.data.createdAt == request.time
                    && (!('source' in request.resource.data)
                        || (request.resource.data.source is string && request.resource.data.source.size() <= 50));
      allow read, update, delete: if false;
    }
  }
}
