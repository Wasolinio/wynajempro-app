# ============================================
# Stripe — Klucze API
# ============================================
# Ustaw te sekrety przez Firebase CLI:
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
#
# UWAGA: NIE wklejaj sekretów tutaj! Ten plik to tylko szablon.
# Sekrety są przechowywane bezpiecznie w Google Cloud Secret Manager.

# Klucz sekretny Stripe (sk_test_... dla testów, sk_live_... dla produkcji)
# STRIPE_SECRET_KEY=sk_test_...

# Klucz podpisu webhooka Stripe (whsec_...)
# STRIPE_WEBHOOK_SECRET=whsec_...
